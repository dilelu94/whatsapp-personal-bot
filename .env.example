# Configuración del Bot de WhatsApp

# 🔔 Telegram Alerts (Opcional pero recomendado)
# Token obtenido de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Tu Chat ID personal (obtenido tras enviarle un mensaje al bot)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 🔗 Vinculación de WhatsApp (Opcional)
# Si se define, el bot usará código de 8 dígitos enviado por Telegram en lugar de código QR en consola.
# Formato: Código de país + número, sin signos '+' ni espacios (Ej: 5491100000000)
WHATSAPP_PAIRING_NUMBER=

# 📅 Google Calendar Integration (Opcional)
# El ID del calendario de Google a escanear (generalmente tu email o 'primary')
GOOGLE_CALENDAR_ID=primary

# Credenciales de Google Cloud Service Account. Puedes configurar UNA de las dos opciones:
# Opción 1 (Recomendada para Docker/Producción): El JSON de credenciales comprimido en una sola línea.
GOOGLE_CREDENTIALS_JSON=
# Opción 2: Ruta absoluta o relativa al archivo físico googleCredentials.json (Por defecto './googleCredentials.json')
GOOGLE_CREDENTIALS_PATH=./googleCredentials.json

# 📂 Rutas de Almacenamiento y Persistencia (Opcional)
# Permite cambiar la ubicación de los datos del bot (útil para Docker).
# DB_PATH=./storage.json
# WWEBJS_AUTH_PATH=./.wwebjs_auth
# MEDIA_DIR=./media

# ⚙️ Entorno de Ejecución
NODE_ENV=production
